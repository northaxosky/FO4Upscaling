# Copy this file to scripts/.env and customize paths for your setup.
# All paths use forward slashes (Git Bash style).

# vcpkg installation
VCPKG_ROOT="C:/Utilities/vcpkg"

# MO2 mod folder where DLLs and assets are deployed
MOD_DIR="C:/Games/Modding/The Midnight Ride/mods/Upscaling + FG Test"

# MO2 executable (for automated testing)
MO2_EXE="C:/Games/Modding/The Midnight Ride/MidnightRide.exe"

# MO2 profile name to launch with
MO2_PROFILE="Test"

# F4SE log directory
F4SE_LOG_DIR="C:/Users/$USER/Documents/My Games/Fallout4/F4SE"
