{
  "name": "aaaframegeneration",
  "version-string": "1.3.3",
  "description": "Frame generation plugin for Fallout 4",
  "supports": "windows & x64",
  "dependencies": [
    "boost-stl-interfaces",
    "fmt",
    "rsm-mmio",
    {
      "name": "spdlog",
      "features": [ "wchar" ]
    },
    "xbyak",
    "directxtk",
    "directxtex",
    "directx-headers",
    "magic-enum",
    "simpleini"
  ]
}
